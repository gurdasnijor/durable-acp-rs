{
  "name": "@durable-acp/server",
  "version": "0.1.0",
  "description": "Durable ACP conductor server — spawn and connect to agents with one import.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "durable-acp-server": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.1",
    "@durable-acp/transport": "workspace:*",
    "durable-session": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@durable-acp/server-darwin-arm64": "0.1.0",
    "@durable-acp/server-darwin-x64": "0.1.0",
    "@durable-acp/server-linux-x64": "0.1.0",
    "@durable-acp/server-linux-arm64": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "vite": "^6.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
